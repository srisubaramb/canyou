// ### Task 5: The "Boss Level" Data Transformation (Heavy `reduce` & Array Chaining)
function normalizeData(data) {
	let result = Object.values(data)
	result = result.flatMap(employee => employee).map(employee => {
		const totalBudget = employee.projects?.reduce((totalAmount,currentObj) => totalAmount + (currentObj?.budget || 0) , 0) || 0
		//remove project by using destructuring
		const {projects, ...rest} = employee
		return {
			...rest,
			totalBudget
		} 
	}).reduce((finalObj, currentObj) => {
		finalObj[currentObj.id] = currentObj
		return finalObj
	},{})
	console.log(result)
}

