// ### Task 3: The "Context" Trap (The `this` keyword & Binding)
const TaxCalculator = {
	baseRate : 0.15,
	calculate (amount) {
		return this.baseRate * amount;
	}
}
function processPayments(paymentsArray, callback) {
	return paymentsArray.map(amount => callback.bind(TaxCalculator)(amount))
}
console.log(processPayments([100, 200, 300], TaxCalculator.calculate))

