const pokemon = () => {
	const pikachu = fetch('https://pokeapi.co/api/v2/pokemon/pikachu')
	const bulbasaur = fetch('https://pokeapi.co/api/v2/pokemon/bulbasaur')
	const charmander = fetch('https://pokeapi.co/api/v2/pokemon/charmander')
	const pokemon = []
	return Promise.all([pikachu,bulbasaur,charmander]).
	then(responses => Promise.all(responses.map(response => response.json()))).then(dataArray => {
		dataArray.forEach(data => pokemon.push(data))
		return pokemon
	})
}
